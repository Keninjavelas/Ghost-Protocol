# ── SSH Gateway ──────────────────────────────────────────────────────────────
SSH_HOST=0.0.0.0
SSH_PORT=2222
SSH_HOST_KEY_PATH=./config/ssh_host_rsa_key

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ghost
POSTGRES_PASSWORD=ghostpass
POSTGRES_DB=ghost_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
# Install: https://ollama.com  |  then: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ── Beacon ────────────────────────────────────────────────────────────────────
BEACON_BASE_URL=http://localhost:8000/beacon

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
