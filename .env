# ── SSH Gateway ──────────────────────────────────────────────────────────────
SSH_HOST=0.0.0.0
SSH_PORT=2222
SSH_HOST_KEY_PATH=./config/ssh_host_rsa_key

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ghost
POSTGRES_PASSWORD=ghostpass
POSTGRES_DB=ghost_db
POSTGRES_HOST=ghost_postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────────
REDIS_HOST=ghost_redis
REDIS_PORT=6379
REDIS_DB=0

# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
# Install: https://ollama.com  |  then: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ── Beacon ────────────────────────────────────────────────────────────────────
BEACON_BASE_URL=http://localhost:8000/beacon

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true

# ── Network Defense (AI-Powered Threat Detection) ────────────────────────────
NETWORK_DEFENSE_ENABLED=false
NETWORK_INTERFACE=any
NETWORK_DEFENSE_ML_ENABLED=true
NETWORK_DEFENSE_ML_MODEL_PATH=
NETWORK_DEFENSE_AUTOMATED_RESPONSE=false
NETWORK_DEFENSE_RESPONSE_DRY_RUN=true
NETWORK_DEFENSE_AUTO_BLOCK_THRESHOLD=80.0
NETWORK_DEFENSE_AUTO_THROTTLE_THRESHOLD=60.0
NETWORK_DEFENSE_ALERT_WEBHOOK=
NETWORK_DEFENSE_LOG_DIR=logs/threats

# ── VPN Security Platform (Metadata-Only Detection) ─────────────────────────
VPN_SECURITY_ENABLED=false
VPN_SECURITY_INTERFACE=any
VPN_SECURITY_POLL_INTERVAL_SECONDS=5.0
